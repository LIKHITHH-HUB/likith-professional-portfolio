---
import { CenterTitle } from "./UI";
import { ContactForm } from "./Preact";
import { Image } from "astro:assets";

//  Import SVGs as normal files
import Github from "../assets/Icons/github.svg";
import Linkedin from "../assets/Icons/linkedin.svg";
import Instagram from "../assets/Icons/instagram.svg";
import Email from "../assets/Icons/gmail.svg";

//  FIX: import image instead of SVG module
import ContactArt from "../assets/Portfolio-pic.png";
---

<section
    id="contact"
    class="w-full min-h-screen px-6 py-16 bg-background relative z-10"
>
    <CenterTitle title="Contact" color="primary" />

    <!-- TEXT -->
    <div class="text-center max-w-2xl mx-auto mt-6">
        <h2 class="gradientText text-3xl font-bold">
            Let’s Build Something Valuable
        </h2>

        <p class="mt-3 text-gray-300">
            I'm a Full Stack Developer focused on building real-world applications.
            If you're hiring or looking for someone who delivers practical solutions,
            feel free to reach out.
        </p>

        <p class="mt-3">
            📩 
            <a href="mailto:likhithrao2223@gmail.com" class="text-primary underline">
                likhithrao2223@gmail.com
            </a>
        </p>
    </div>

    <!-- MAIN -->
    <div class="flex flex-col lg:flex-row items-center justify-center gap-16 mt-16">

        <!-- LEFT -->
        <div class="relative flex items-center justify-center">

            <!-- CIRCLE -->
            <div
                class="relative w-[320px] h-[320px] border-2 border-dashed border-white/30 rounded-full"
            >

                <!-- ICONS -->
                <a href="mailto:likhithrao2223@gmail.com" class="socialIcon">
                    <img src={Email.src} alt="email" width="24" />
                </a>

                <a href="https://github.com/LIKHITHH-HUB" class="socialIcon">
                    <img src={Github} alt="GitHub" width="24" />
                </a>

                <a href="https://www.linkedin.com/in/thandla-likhith-in/" class="socialIcon">
                    <img src={Linkedin} alt="linkedin" width="24" />
                </a>

                <a href="https://www.instagram.com/___likhith___15/" class="socialIcon">
                    <img src={Instagram} alt="instagram" width="24" />
                </a>

            </div>

            <!-- IMAGE (NOT SVG MODULE) -->
            <Image
                src={ContactArt}
                alt="contact"
                class="absolute bottom-10 w-[260px] z-10"
            />
        </div>

        <!-- FORM -->
        <div class="w-full max-w-[500px] z-10">
            <ContactForm client:load />
        </div>
    </div>
</section>

<style>
.socialIcon {
    position: absolute;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px dashed rgba(255,255,255,0.3);
    border-radius: 50%;
    background: black;
    transition: all 0.3s ease;
}

.socialIcon img {
    width: 24px;
    height: 24px;
}

/* POSITION */
.socialIcon:nth-child(1) { top: -10px; left: 50%; transform: translateX(-50%); }
.socialIcon:nth-child(2) { left: -10px; top: 50%; transform: translateY(-50%); }
.socialIcon:nth-child(3) { right: -10px; top: 50%; transform: translateY(-50%); }
.socialIcon:nth-child(4) { bottom: -10px; left: 50%; transform: translateX(-50%); }

/* HOVER */
.socialIcon:hover {
    transform: scale(1.15);
    border-color: #a855f7;
    box-shadow: 0 0 20px #a855f7;
}
</style>