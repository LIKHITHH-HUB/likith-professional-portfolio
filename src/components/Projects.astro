---
import { ExternalLinkIcon, WrenchIcon } from "lucide-preact";
import { SectionTitle } from "./UI";
import { Image } from "astro:assets";
import { ProjectsList } from "../utils/ProjectsList";
---

<section
    id="projects"
    class="w-full min-h-screen px-6 py-4 pt-14 bg-background"
>
    <SectionTitle title="My Projects" color="secondary">
        <div
            class="Fade_Up relative w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:px-12 pb-6"
        >
            {
                ProjectsList?.map((project: any) => {
                    if (project?.hideProject) return null;

                    return (
                        <div class="Project_Stagger Card_Main w-full flex flex-col bg-cardGradient overflow-hidden rounded-[0.4em] mt-3">

                            <!-- IMAGE -->
                            <a
                                href={`/projects/${project?.Name.replaceAll(" ", "-").toLowerCase()}`}
                                class="w-full relative"
                            >
                                <Image
                                    class="opacity-50 w-full"
                                    src={project.Shot}
                                    alt={project.Name}
                                />

                                <Image
                                    class="absolute left-6 bottom-6"
                                    src={project.Logo}
                                    alt={project.Name}
                                    width={project.LogoSize}
                                    height={project.LogoSize}
                                />
                            </a>

                            <!-- CONTENT -->
                            <div class="w-full px-4 py-3">

                                <!-- TITLE + LINK -->
                                <div class="flex justify-between items-center">
                                    <h3 class="font-ubuntu text-[1.4em]">
                                        {project.Name}
                                    </h3>

                                    <div class="flex items-center gap-2">

                                        {project.Status === "development" && (
                                            <div class="flex items-center gap-1 text-orange-400 text-sm">
                                                <WrenchIcon size={14} />
                                                <span>Dev</span>
                                            </div>
                                        )}

                                        <a
                                            href={project.Link}
                                            target="_blank"
                                        >
                                            <ExternalLinkIcon />
                                        </a>
                                    </div>
                                </div>

                                <!-- DESCRIPTION -->
                                <p class="text-sm text-center mt-2">
                                    {project.ShortDesc}
                                </p>

                                <!--  FIXED TECH STACK -->
                                <div class="flex justify-center gap-3 mt-3">
                                    {
                                        project.Tech.map((tech: any) => (
                                            <Image
                                                src={tech.Icon}
                                                alt={`Tech ${tech.title}`}
                                                width={22}
                                                height={22}
                                            />
                                        ))
                                    }
                                </div>

                            </div>
                        </div>
                    );
                })
            }
        </div>
    </SectionTitle>
</section>