---
export async function getStaticPaths() {
    const { ProjectsList } = await import("../../utils/ProjectsList");

    return ProjectsList.map((project: any) => ({
        params: {
            projectID: project.Name.replaceAll(" ", "-").toLowerCase(),
        },
    }));
}

const { projectID } = Astro.params;

import { Image } from "astro:assets";
import { ProjectLayout } from "../../layouts";
import { CenterTitle, SectionTitle } from "../../components/UI";
import { ProjectsList } from "../../utils/ProjectsList";

const project = ProjectsList.find(
    (itm: any) =>
        itm.Name.replaceAll(" ", "-").toLowerCase() === projectID
);

if (!project) {
    throw new Error(`Project not found for ID: ${projectID}`);
}
---

<ProjectLayout
    title={`${project.Name} | Likhith`}
    description={project.ShortDesc}
>

    <div class="flex_center flex-col gap-4 py-4">
        <h1>{project.Name}</h1>

        <div class="flex gap-4">
            {project.Tech?.map((tech: any, index: number) => (
                <Image
                    src={tech.icon}
                    alt={`tech-${index}`}
                    width={28}
                    height={28}
                />
            ))}
        </div>

        <div class="flex gap-4">
            <a href={project.Source} target="_blank">
                Source Code
            </a>

            <!-- FIXED -->
            <a href={project.Link} target="_blank">
                Live Demo →
            </a>
        </div>
    </div>

</ProjectLayout>