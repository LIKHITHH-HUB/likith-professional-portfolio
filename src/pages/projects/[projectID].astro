---
export async function getStaticPaths() {
    const { ProjectsList } = await import("../../utils/ProjectsList");

    return ProjectsList.map((project: any) => ({
        params: {
            projectID: project.Name.replaceAll(" ", "-").toLowerCase(),
        },
    }));
}

const { projectID } = Astro.params;

import { Image } from "astro:assets";
import { ProjectLayout } from "../../layouts";
import { ExternalLinkIcon } from "lucide-preact";
import { CenterTitle, SectionTitle } from "../../components/UI";
import { ProjectsList } from "../../utils/ProjectsList";

// SAFE FIND
const project = ProjectsList.find(
    (itm: any) =>
        itm.Name.replaceAll(" ", "-").toLowerCase() === projectID
);

// HARD FAIL
if (!project) {
    throw new Error(`Project not found for ID: ${projectID}`);
}
---

<ProjectLayout
    title={`${project.Name} | Likhith`}
    description={project.ShortDesc}
>

    <!-- BACKGROUND -->
    <div class="flex_center absolute inset-0 w-full h-full z-[-1]">
        <Image
            src={project.Shot}
            alt={`${project.Name}_BG`}
            class="w-full h-full opacity-50 blur-md p-6 object-cover"
        />
        <div class="bg-imgOverlayGradient w-full h-full absolute inset-0"></div>
    </div>

    <!-- HEADER -->
    <div class="flex_center flex-col gap-4 py-4">
        <Image
            src={project.Logo}
            alt={project.Name}
            width={100}
            height={100}
        />

        <h1 class="text-[1.6em] md:text-[1.8em] text-center">
            {project.Name}
        </h1>

        <!-- TECH ICONS -->
        <div class="flex gap-4">
            {
                project.Tech && project.Tech.map((tech: any, index: number) => (
                    <Image
                        src={tech.icon}
                        alt={`tech-${index}`}
                        width={28}
                        height={28}
                    />
                ))
            }
        </div>

        <!-- BUTTONS -->
        <div class="flex gap-4">
            <a href={project.Source} target="_blank">
                Source Code
            </a>

            <a href={project.Link} target="_blank">
                <ExternalLinkIcon />
                Live Demo
            </a>
        </div>
    </div>

    <!-- ABOUT -->
    <h2 class="text-[1.5em] pt-4 pb-3">
        About the project
    </h2>

    <div class="flex flex-col xl:flex-row gap-4 py-10">
        <Image
            src={project.Mockup}
            alt="mockup"
            width={600}
        />

        <div>
            <p class="text-[1.1em] px-4">
                {project.Desc}
            </p>
        </div>
    </div>

    <!-- FEATURES -->
    <SectionTitle title="Features" color="primary">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {
                project.features && project.features.map((item: any) => (
                    <div>
                        <span class="text-[1.125em]">
                            {item.title}
                        </span>
                        <p>{item.description}</p>
                    </div>
                ))
            }
        </div>
    </SectionTitle>

    <!-- TECH STACK -->
    <CenterTitle title="Tech Stack" color="secondary" />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-40">
        {
            project.Tech && project.Tech.map((tech: any) => (
                <div>
                    <div class="flex gap-4">
                        <Image
                            src={tech.icon}
                            alt={tech.title}
                            width={40}
                            height={40}
                        />
                        <span>{tech.title}</span>
                    </div>
                    <p>{tech.description}</p>
                </div>
            ))
        }
    </div>

</ProjectLayout>